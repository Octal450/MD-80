						</difference>
						<value>3.06</value> <!-- MAC length, fudged for balance accuracy -->
					</quotient>
					<value>100</value>
				</product>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/load-manager/cg-aft-limit"> <!-- From FCOM -->
			<function>
				<table>
					<independentVar lookup="row">/systems/load-manager/gw-lbs</independentVar>
