			</function>
		</fcs_function>
		
		<fcs_function name="/systems/load-manager/cg-fwd-limit"> <!-- From FCOM -->
			<function>
				<table>
					<independentVar lookup="row">/systems/load-manager/gw-lbs</independentVar>
					<independentVar lookup="column">zero</independentVar> <!-- Take advantage of the table lookup to interpolate -->
					<independentVar lookup="table">/options/model-int</independentVar>
