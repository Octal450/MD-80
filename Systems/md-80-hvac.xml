<?xml version="1.0"?>

<!-- McDonnell Douglas MD-80 HVAC -->
<!-- Copyright (c) 2026 Josh Davidson (Octal450) -->

<system name="MD-80: HVAC"> <!-- The airplane is calibrated in Fahrenheit since it's American designed, so that's what I'll use here -->
	
	<property value="72">/systems/pneumatics/hvac/cabin-temp</property>
	<property value="72">/systems/pneumatics/hvac/cockpit-temp</property>
	
	<channel name="General" execrate="8">
		
		<fcs_function name="/systems/pneumatics/hvac/tat-f">
			<function>
				<sum>
					<product>
						<property>propulsion/tat-c</property>
						<value>1.8</value>
					</product>
					<value>32</value>
				</sum>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/bleed-l-f">
			<function>
				<sum>
					<product>
						<property>/systems/pneumatics/temp/bleed-l</property>
						<value>1.8</value>
					</product>
					<value>32</value>
				</sum>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/bleed-r-f">
			<function>
				<sum>
					<product>
						<property>/systems/pneumatics/temp/bleed-r</property>
						<value>1.8</value>
					</product>
					<value>32</value>
				</sum>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/trim-air-f">
			<function>
				<sum>
					<product>
						<property>/systems/pneumatics/temp/trim-air</property>
						<value>1.8</value>
					</product>
					<value>32</value>
				</sum>
			</function>
		</fcs_function>
		
		<summer name="/systems/pneumatics/hvac/pack-flow-sum">
			<input>/systems/pneumatics/pack-l-flow</input>
			<input>/systems/pneumatics/pack-r-flow</input>
			<clipto>
				<min>0</min>
				<max>24</max>
			</clipto>
		</summer>
		
		<!-- Knob Targets -->
		<fcs_function name="/systems/pneumatics/hvac/cockpit-target">
			<function>
				<table>
					<independentVar lookup="row">/controls/pneumatics/cockpit-temp</independentVar>
					<tableData>
						65   0
						66  66
						80  80
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/cabin-target">
			<function>
				<table>
					<independentVar lookup="row">/controls/pneumatics/cabin-temp</independentVar>
					<tableData>
						65   0
						66  66
						80  80
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<!-- Switched Temperature Targets -->
		<switch name="/systems/pneumatics/hvac/cockpit-target-switched">
			<default value="/systems/pneumatics/hvac/cockpit-temp"/>
			<test value="/systems/pneumatics/hvac/cockpit-target">
				/systems/pneumatics/hvac/cockpit-target ge 60
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/cabin-target-switched">
			<default value="/systems/pneumatics/hvac/cabin-temp"/>
			<test value="/systems/pneumatics/hvac/cabin-target">
				/systems/pneumatics/hvac/cabin-target ge 60
			</test>
		</switch>
		
		<!-- Temperature Error -->
		<summer name="/systems/pneumatics/hvac/cockpit-error">
			<input>/systems/pneumatics/hvac/cockpit-target-switched</input>
			<input>-/systems/pneumatics/hvac/cockpit-temp</input>
		</summer>
		
		<summer name="/systems/pneumatics/hvac/cabin-error">
			<input>/systems/pneumatics/hvac/cabin-target-switched</input>
			<input>-/systems/pneumatics/hvac/cabin-temp</input>
		</summer>
	
	</channel>
	
	<channel name="Pack Temperature" execrate="8">
		
		<!-- Pack Temperature Targets -->
		<!-- This is complex because the ECS controls which packs respond based on which zones have error, and accounts for inoperative packs -->
		<switch name="/systems/pneumatics/hvac/pack-l-flowing">
			<default value="1"/>
			<test value="0">
				/systems/pneumatics/pack-l-flow lt 10
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/pack-r-flowing">
			<default value="1"/>
			<test value="0">
				/systems/pneumatics/pack-r-flow lt 10
			</test>
		</switch>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-l-target-input">
			<function>
				<min>
					<property>/systems/pneumatics/hvac/cockpit-target-switched</property>
					<ifthen>
						<eq>
							<property>/systems/pneumatics/hvac/pack-r-flowing</property>
							<value>0</value>
						</eq>
						<property>/systems/pneumatics/hvac/cabin-target-switched</property>
						<value>1000</value> <!-- Ignore -->
					</ifthen>
				</min>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-l-error-input">
			<function>
				<min>
					<property>/systems/pneumatics/hvac/cockpit-error</property>
					<ifthen>
						<eq>
							<property>/systems/pneumatics/hvac/pack-r-flowing</property>
							<value>0</value>
						</eq>
						<property>/systems/pneumatics/hvac/cabin-error</property>
						<value>1000</value> <!-- Ignore -->
					</ifthen>
				</min>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-r-target-input">
			<function>
				<min>
					<property>/systems/pneumatics/hvac/cabin-target-switched</property>
					<ifthen>
						<eq>
							<property>/systems/pneumatics/hvac/pack-l-flowing</property>
							<value>0</value>
						</eq>
						<property>/systems/pneumatics/hvac/cockpit-target-switched</property>
						<value>1000</value> <!-- Ignore -->
					</ifthen>
				</min>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-r-error-input">
			<function>
				<min>
					<property>/systems/pneumatics/hvac/cabin-error</property>
					<ifthen>
						<eq>
							<property>/systems/pneumatics/hvac/pack-l-flowing</property>
							<value>0</value>
						</eq>
						<property>/systems/pneumatics/hvac/cockpit-error</property>
						<value>1000</value> <!-- Ignore -->
					</ifthen>
				</min>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-l-target">
			<function>
				<ifthen>
					<lt>
						<property>/systems/pneumatics/hvac/cockpit-target</property>
						<value>60</value>
					</lt>
					<value>62</value>
					<sum>
						<property>/systems/pneumatics/hvac/pack-temp/pack-l-target-input</property>
						<table>
							<independentVar lookup="row">/systems/pneumatics/hvac/pack-temp/pack-l-error-input</independentVar>
							<tableData>
								-4 -8.4
								 0 -0.4
								 4  4.6
							</tableData>
						</table>
					</sum>
				</ifthen>
			</function>
			<clipto>
				<min>55</min>
				<max>95</max>
			</clipto>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-r-target">
			<function>
				<ifthen>
					<lt>
						<property>/systems/pneumatics/hvac/cabin-target</property>
						<value>60</value>
					</lt>
					<value>62</value>
					<sum>
						<property>/systems/pneumatics/hvac/pack-temp/pack-r-target-input</property>
						<table>
							<independentVar lookup="row">/systems/pneumatics/hvac/pack-temp/pack-r-error-input</independentVar>
							<tableData>
								-4 -8.7
								 0 -0.7
								 4  4.3
							</tableData>
						</table>
					</sum>
				</ifthen>
			</function>
			<clipto>
				<min>55</min>
				<max>95</max>
			</clipto>
		</fcs_function>
		
		<!-- L Pack Temperature -->
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-l-cmd">
			<function>
				<interpolate1d>
					<property>/systems/pneumatics/pack-l-flow</property>
					<value>0</value><property>/systems/pneumatics/hvac/tat-f</property>
					<value>10</value><min>
						<property>/systems/pneumatics/hvac/bleed-l-f</property>
						<property>/systems/pneumatics/hvac/pack-temp/pack-l-target</property>
					</min>
				</interpolate1d>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-l-incr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-l-flow</independentVar>
					<tableData>
						 0  0.1
						10  4.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-l-decr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-l-flow</independentVar>
					<tableData>
						 0  0.1
						10  3.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<actuator name="/systems/pneumatics/hvac/pack-temp/pack-l-actuator">
			<input>/systems/pneumatics/hvac/pack-temp/pack-l-cmd</input>
			<rate_limit sense="incr">/systems/pneumatics/hvac/pack-temp/pack-l-incr-rate</rate_limit>
			<rate_limit sense="decr">/systems/pneumatics/hvac/pack-temp/pack-l-decr-rate</rate_limit>
		</actuator>
		
		<lag_filter name="/systems/pneumatics/hvac/pack-temp/pack-l">
			<input>/systems/pneumatics/hvac/pack-temp/pack-l-actuator</input>
			<c1>0.4</c1>
		</lag_filter>
		
		<!-- R Pack Temperature -->
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-r-cmd">
			<function>
				<interpolate1d>
					<property>/systems/pneumatics/pack-r-flow</property>
					<value>0</value><property>/systems/pneumatics/hvac/tat-f</property>
					<value>10</value><min>
						<property>/systems/pneumatics/hvac/bleed-r-f</property>
						<property>/systems/pneumatics/hvac/pack-temp/pack-r-target</property>
					</min>
				</interpolate1d>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-r-incr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-r-flow</independentVar>
					<tableData>
						 0  0.1
						10  4.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-r-decr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-r-flow</independentVar>
					<tableData>
						 0  0.1
						10  3.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<actuator name="/systems/pneumatics/hvac/pack-temp/pack-r-actuator">
			<input>/systems/pneumatics/hvac/pack-temp/pack-r-cmd</input>
			<rate_limit sense="incr">/systems/pneumatics/hvac/pack-temp/pack-r-incr-rate</rate_limit>
			<rate_limit sense="decr">/systems/pneumatics/hvac/pack-temp/pack-r-decr-rate</rate_limit>
		</actuator>
		
		<lag_filter name="/systems/pneumatics/hvac/pack-temp/pack-r">
			<input>/systems/pneumatics/hvac/pack-temp/pack-r-actuator</input>
			<c1>0.4</c1>
		</lag_filter>
		
		<!-- Conditioned Air Manifold Temperature -->
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-l-flow-factor">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-l-flow</independentVar>
					<tableData>
						 0  0
						10  1
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-r-flow-factor">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-r-flow</independentVar>
					<tableData>
						 0  0
						10  1
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/conditioned-air-temp-cmd"> <!-- Because packs aren't controlled uniformly -->
			<function>
				<ifthen>
					<gt>
						<sum>
							<property>/systems/pneumatics/hvac/pack-temp/pack-l-flow-factor</property>
							<property>/systems/pneumatics/hvac/pack-temp/pack-r-flow-factor</property>
						</sum>
						<value>0</value>
					</gt>
					<min>
						<ifthen>
							<gt>
								<property>/systems/pneumatics/hvac/pack-temp/pack-l-flow-factor</property>
								<value>0</value>
							</gt>
							<property>/systems/pneumatics/hvac/pack-temp/pack-l-actuator</property>
							<value>1000</value> <!-- Ignore -->
						</ifthen>
						<ifthen>
							<gt>
								<property>/systems/pneumatics/hvac/pack-temp/pack-r-flow-factor</property>
								<value>0</value>
							</gt>
							<property>/systems/pneumatics/hvac/pack-temp/pack-r-actuator</property>
							<value>1000</value> <!-- Ignore -->
						</ifthen>
					</min>
					<min>
						<property>/systems/pneumatics/hvac/pack-temp/pack-l-actuator</property>
						<property>/systems/pneumatics/hvac/pack-temp/pack-r-actuator</property>
					</min>
				</ifthen>
			</function>
		</fcs_function>
		
		<lag_filter name="/systems/pneumatics/hvac/conditioned-air-temp">
			<input>/systems/pneumatics/hvac/conditioned-air-temp-cmd</input>
			<c1>0.4</c1>
		</lag_filter>
	
	</channel>
	
	<channel name="Duct Temperature/Trim Air Mixing" execrate="8">
		
		<!-- Duct Temperature Targets -->
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cockpit-target">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/cockpit-target-switched</property>
					<table>
						<independentVar lookup="row">/systems/pneumatics/hvac/cockpit-error</independentVar>
						<tableData>
							-4 -8
							 0  0
							 4  8
						</tableData>
					</table>
				</sum>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cabin-target">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/cabin-target-switched</property>
					<table>
						<independentVar lookup="row">/systems/pneumatics/hvac/cabin-error</independentVar>
						<tableData>
							-4 -8
							 0  0
							 4  8
						</tableData>
					</table>
				</sum>
			</function>
		</fcs_function>
		
		<!-- Cockpit Duct Temperature/Trim Air Mixing -->
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cockpit-cond-air">
			<function>
				<interpolate1d>
					<property>/systems/pneumatics/hvac/pack-flow-sum</property>
					<value>0</value><property>/systems/pneumatics/hvac/cockpit-temp</property>
					<value>20</value><property>/systems/pneumatics/hvac/conditioned-air-temp</property>
				</interpolate1d>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cockpit-trim-air">
			<function>
				<interpolate1d>
					<property>/systems/pneumatics/trim-air-psi</property>
					<value>0</value><property>/systems/pneumatics/hvac/cockpit-temp</property>
					<value>20</value><property>/systems/pneumatics/hvac/trim-air-f</property>
				</interpolate1d>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cockpit-regulator-cmd">
			<function>
				<ifthen>
					<lt>
						<property>/systems/pneumatics/hvac/cockpit-target</property>
						<value>60</value>
					</lt>
					<sum>
						<property>/systems/pneumatics/hvac/duct-temp/cockpit-regulator-cmd</property>
						<product>
							<property>/controls/pneumatics/cockpit-slew</property>
							<value>0.01</value>
						</product>
					</sum>
					<product>
						<quotient>
							<difference>
								<property>/systems/pneumatics/hvac/duct-temp/cockpit-target</property>
								<property>/systems/pneumatics/hvac/duct-temp/cockpit-cond-air</property>
							</difference>
							<difference>
								<property>/systems/pneumatics/hvac/duct-temp/cockpit-trim-air</property>
								<property>/systems/pneumatics/hvac/duct-temp/cockpit-target</property>
							</difference>
						</quotient>
						<value>10</value> <!-- Compensate for the 0.1 gain in actual trim -->
					</product>
				</ifthen>
			</function>
			<clipto>
				<min>0</min>
				<max>1</max>
			</clipto>
		</fcs_function>
		
		<lag_filter name="/systems/pneumatics/hvac/duct-temp/cockpit-regulator-lag">
			<input>/systems/pneumatics/hvac/duct-temp/cockpit-regulator-cmd</input>
			<c1>5.0</c1>
		</lag_filter>
		
		<pure_gain name="/systems/pneumatics/hvac/duct-temp/cockpit-regulator-valve">
			<input>/systems/pneumatics/hvac/duct-temp/cockpit-regulator-lag</input>
			<gain>0.1</gain> <!-- 0.1 max authority -->
		</pure_gain>
		
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cockpit-cmd">
			<function>
				<quotient>
					<sum>
						<property>/systems/pneumatics/hvac/duct-temp/cockpit-cond-air</property>
						<product>
							<property>/systems/pneumatics/hvac/duct-temp/cockpit-trim-air</property>
							<property>/systems/pneumatics/hvac/duct-temp/cockpit-regulator-valve</property>
						</product>
					</sum>
					<sum>
						<value>1</value>
						<property>/systems/pneumatics/hvac/duct-temp/cockpit-regulator-valve</property>
					</sum>
				</quotient>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cockpit-flow">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/pack-flow-sum</property>
					<product>
						<property>/systems/pneumatics/trim-air-psi</property>
						<property>/systems/pneumatics/hvac/duct-temp/cockpit-regulator-valve</property>
					</product>
				</sum>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cockpit-incr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/hvac/duct-temp/cockpit-flow</independentVar>
					<tableData>
						 0  0.1
						10  2.5
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cockpit-decr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/hvac/duct-temp/cockpit-flow</independentVar>
					<tableData>
						 0  0.1
						10  2.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<actuator name="/systems/pneumatics/hvac/duct-temp/cockpit-actuator">
			<input>/systems/pneumatics/hvac/duct-temp/cockpit-cmd</input>
			<rate_limit sense="incr">/systems/pneumatics/hvac/duct-temp/cockpit-incr-rate</rate_limit>
			<rate_limit sense="decr">/systems/pneumatics/hvac/duct-temp/cockpit-decr-rate</rate_limit>
		</actuator>
		
		<lag_filter name="/systems/pneumatics/hvac/duct-temp/cockpit">
			<input>/systems/pneumatics/hvac/duct-temp/cockpit-actuator</input>
			<c1>0.4</c1>
		</lag_filter>
		
		<!-- Cabin Duct Temperature/Trim Air Mixing -->
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cabin-cond-air">
			<function>
				<interpolate1d>
					<property>/systems/pneumatics/hvac/pack-flow-sum</property>
					<value>0</value><property>/systems/pneumatics/hvac/cabin-temp</property>
					<value>20</value><property>/systems/pneumatics/hvac/conditioned-air-temp</property>
				</interpolate1d>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cabin-trim-air">
			<function>
				<interpolate1d>
					<property>/systems/pneumatics/trim-air-psi</property>
					<value>0</value><property>/systems/pneumatics/hvac/cabin-temp</property>
					<value>20</value><property>/systems/pneumatics/hvac/trim-air-f</property>
				</interpolate1d>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cabin-regulator-cmd">
			<function>
				<ifthen>
					<lt>
						<property>/systems/pneumatics/hvac/cabin-target</property>
						<value>60</value>
					</lt>
					<sum>
						<property>/systems/pneumatics/hvac/duct-temp/cabin-regulator-cmd</property>
						<product>
							<property>/controls/pneumatics/cabin-slew</property>
							<value>0.01</value>
						</product>
					</sum>
					<product>
						<quotient>
							<difference>
								<property>/systems/pneumatics/hvac/duct-temp/cabin-target</property>
								<property>/systems/pneumatics/hvac/duct-temp/cabin-cond-air</property>
							</difference>
							<difference>
								<property>/systems/pneumatics/hvac/duct-temp/cabin-trim-air</property>
								<property>/systems/pneumatics/hvac/duct-temp/cabin-target</property>
							</difference>
						</quotient>
						<value>10</value> <!-- Compensate for the 0.1 gain in actual trim -->
					</product>
				</ifthen>
			</function>
			<clipto>
				<min>0</min>
				<max>1</max>
			</clipto>
		</fcs_function>
		
		<lag_filter name="/systems/pneumatics/hvac/duct-temp/cabin-regulator-lag">
			<input>/systems/pneumatics/hvac/duct-temp/cabin-regulator-cmd</input>
			<c1>5.0</c1>
		</lag_filter>
		
		<pure_gain name="/systems/pneumatics/hvac/duct-temp/cabin-regulator-valve">
			<input>/systems/pneumatics/hvac/duct-temp/cabin-regulator-lag</input>
			<gain>0.1</gain> <!-- 0.1 max authority -->
		</pure_gain>
		
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cabin-cmd">
			<function>
				<quotient>
					<sum>
						<property>/systems/pneumatics/hvac/duct-temp/cabin-cond-air</property>
						<product>
							<property>/systems/pneumatics/hvac/duct-temp/cabin-trim-air</property>
							<property>/systems/pneumatics/hvac/duct-temp/cabin-regulator-valve</property>
						</product>
					</sum>
					<sum>
						<value>1</value>
						<property>/systems/pneumatics/hvac/duct-temp/cabin-regulator-valve</property>
					</sum>
				</quotient>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cabin-flow">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/pack-flow-sum</property>
					<product>
						<property>/systems/pneumatics/trim-air-psi</property>
						<property>/systems/pneumatics/hvac/duct-temp/cabin-regulator-valve</property>
					</product>
				</sum>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cabin-incr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/hvac/duct-temp/cabin-flow</independentVar>
					<tableData>
						 0  0.1
						10  2.5
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/duct-temp/cabin-decr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/hvac/duct-temp/cabin-flow</independentVar>
					<tableData>
						 0  0.1
						10  2.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<actuator name="/systems/pneumatics/hvac/duct-temp/cabin-actuator">
			<input>/systems/pneumatics/hvac/duct-temp/cabin-cmd</input>
			<rate_limit sense="incr">/systems/pneumatics/hvac/duct-temp/cabin-incr-rate</rate_limit>
			<rate_limit sense="decr">/systems/pneumatics/hvac/duct-temp/cabin-decr-rate</rate_limit>
		</actuator>
		
		<lag_filter name="/systems/pneumatics/hvac/duct-temp/cabin">
			<input>/systems/pneumatics/hvac/duct-temp/cabin-actuator</input>
			<c1>0.4</c1>
		</lag_filter>
	
	</channel>
	
	<channel name="Compartment Temperatures" execrate="8">
		
		<!-- Cockpit Temperature -->
		<summer name="/systems/pneumatics/hvac/cockpit-temp-environment-error">
			<input>/systems/pneumatics/hvac/cockpit-temp</input>
			<input>-/systems/pneumatics/hvac/tat-f</input>
			<clipto>
				<min>-15</min>
				<max>15</max>
			</clipto>
		</summer>
		
		<switch name="/systems/pneumatics/hvac/cockpit-temp-environment-rate">
			<default value="0"/>
			<test value="-0.00045">
				/systems/pneumatics/hvac/cockpit-temp-environment-error gt 0.001
			</test>
			<test value="-0.0003">
				/systems/pneumatics/hvac/cockpit-temp-environment-error lt -0.001
			</test>
		</switch>
		
		<summer name="/systems/pneumatics/hvac/cockpit-temp-coupling-error">
			<input>/systems/pneumatics/hvac/cockpit-temp</input>
			<input>-/systems/pneumatics/hvac/cabin-temp</input>
			<clipto>
				<min>-5</min>
				<max>5</max>
			</clipto>
		</summer>
		
		<switch name="/systems/pneumatics/hvac/cockpit-temp-coupling-rate">
			<default value="0"/>
			<test value="-0.0009">
				/systems/pneumatics/hvac/cockpit-temp-coupling-error gt 0.001
			</test>
			<test value="-0.0006">
				/systems/pneumatics/hvac/cockpit-temp-coupling-error lt -0.001
			</test>
		</switch>
		
		<summer name="/systems/pneumatics/hvac/cockpit-temp-duct-error">
			<input>/systems/pneumatics/hvac/cockpit-temp</input>
			<input>-/systems/pneumatics/hvac/duct-temp/cockpit</input>
			<clipto>
				<min>-10</min>
				<max>10</max>
			</clipto>
		</summer>
		
		<fcs_function name="/systems/pneumatics/hvac/cockpit-temp-duct-rate">
			<function>
				<ifthen>
					<ge>
						<property>/systems/pneumatics/hvac/cockpit-temp-duct-error</property>
						<value>0</value>
					</ge>
					<product>
						<property>/systems/pneumatics/hvac/duct-temp/cockpit-flow</property>
						<value>-0.0005</value>
					</product>
					<product>
						<property>/systems/pneumatics/hvac/duct-temp/cockpit-flow</property>
						<value>-0.00045</value>
					</product>
				</ifthen>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/cockpit-temp-calc">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/cockpit-temp</property>
					<product> <!-- Environment factor -->
						<property>/systems/pneumatics/hvac/cockpit-temp-environment-error</property>
						<property>/systems/pneumatics/hvac/cockpit-temp-environment-rate</property>
						<property>simulation/channel-dt</property>
					</product>
					<product> <!-- Coupling factor -->
						<property>/systems/pneumatics/hvac/cockpit-temp-coupling-error</property>
						<property>/systems/pneumatics/hvac/cockpit-temp-coupling-rate</property>
						<property>simulation/channel-dt</property>
					</product>
					<product> <!-- Duct flow factor -->
						<property>/systems/pneumatics/hvac/cockpit-temp-duct-error</property>
						<property>/systems/pneumatics/hvac/cockpit-temp-duct-rate</property>
						<property>simulation/channel-dt</property>
					</product>
				</sum>
			</function>
			<output>/systems/pneumatics/hvac/cockpit-temp</output>
			<clipto> <!-- Keep it reasonable -->
				<min>32</min>
				<max>99</max>
			</clipto>
		</fcs_function>
		
		<!-- Cabin Temperature -->
		<summer name="/systems/pneumatics/hvac/cabin-temp-environment-error">
			<input>/systems/pneumatics/hvac/cabin-temp</input>
			<input>-/systems/pneumatics/hvac/tat-f</input>
			<clipto>
				<min>-15</min>
				<max>15</max>
			</clipto>
		</summer>
		
		<switch name="/systems/pneumatics/hvac/cabin-temp-environment-rate">
			<default value="0"/>
			<test value="-0.00045">
				/systems/pneumatics/hvac/cabin-temp-environment-error gt 0.001
			</test>
			<test value="-0.0003">
				/systems/pneumatics/hvac/cabin-temp-environment-error lt -0.001
			</test>
		</switch>
		
		<summer name="/systems/pneumatics/hvac/cabin-temp-coupling-error">
			<input>/systems/pneumatics/hvac/cabin-temp</input>
			<input>-/systems/pneumatics/hvac/cockpit-temp</input>
			<clipto>
				<min>-5</min>
				<max>5</max>
			</clipto>
		</summer>
		
		<switch name="/systems/pneumatics/hvac/cabin-temp-coupling-rate">
			<default value="0"/>
			<test value="-0.0009">
				/systems/pneumatics/hvac/cabin-temp-coupling-error gt 0.001
			</test>
			<test value="-0.0006">
				/systems/pneumatics/hvac/cabin-temp-coupling-error lt -0.001
			</test>
		</switch>
		
		<summer name="/systems/pneumatics/hvac/cabin-temp-duct-error">
			<input>/systems/pneumatics/hvac/cabin-temp</input>
			<input>-/systems/pneumatics/hvac/duct-temp/cabin</input>
			<clipto>
				<min>-10</min>
				<max>10</max>
			</clipto>
		</summer>
		
		<fcs_function name="/systems/pneumatics/hvac/cabin-temp-duct-rate">
			<function>
				<ifthen>
					<ge>
						<property>/systems/pneumatics/hvac/cabin-temp-duct-error</property>
						<value>0</value>
					</ge>
					<product>
						<property>/systems/pneumatics/hvac/duct-temp/cabin-flow</property>
						<value>-0.0005</value>
					</product>
					<product>
						<property>/systems/pneumatics/hvac/duct-temp/cabin-flow</property>
						<value>-0.00045</value>
					</product>
				</ifthen>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/cabin-temp-calc">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/cabin-temp</property>
					<product> <!-- Environment factor -->
						<property>/systems/pneumatics/hvac/cabin-temp-environment-error</property>
						<property>/systems/pneumatics/hvac/cabin-temp-environment-rate</property>
						<property>simulation/channel-dt</property>
					</product>
					<product> <!-- Coupling factor -->
						<property>/systems/pneumatics/hvac/cabin-temp-coupling-error</property>
						<property>/systems/pneumatics/hvac/cabin-temp-coupling-rate</property>
						<property>simulation/channel-dt</property>
					</product>
					<product> <!-- Duct flow factor -->
						<property>/systems/pneumatics/hvac/cabin-temp-duct-error</property>
						<property>/systems/pneumatics/hvac/cabin-temp-duct-rate</property>
						<property>simulation/channel-dt</property>
					</product>
				</sum>
			</function>
			<output>/systems/pneumatics/hvac/cabin-temp</output>
			<clipto> <!-- Keep it reasonable -->
				<min>32</min>
				<max>99</max>
			</clipto>
		</fcs_function>
	
	</channel>

</system>
