<PropertyList>
	
	<path>trp.ac</path>
	
	<effect>
		<inherits-from>Effects/model-transparent</inherits-from>
		<object-name>clOn</object-name>
		<object-name>crOn</object-name>
		<object-name>flxOn</object-name>
		<object-name>gaOn</object-name>
		<object-name>mctOn</object-name>
		<object-name>NoMode</object-name>
		<object-name>Text</object-name>
		<object-name>toOn</object-name>
	</effect>
	
	<animation>
		<type>material</type>
		<object-name>Text</object-name>
		<emission>
			<red>1.0</red>
			<green>0.6</green>
			<blue>0.3</blue>
			<factor-prop>systems/lighting/center-panel</factor-prop>
		</emission>
	</animation>
	
	<animation>
		<type>knob</type>
		<object-name>assumedTemp</object-name>
		<property>controls/cockpit/trp/assumed-temp-rotate</property>
		<factor>-7</factor>
		<center>
			<x-m>0</x-m>
			<y-m>0.0188</y-m>
			<z-m>0.031</z-m>
		</center>
		<axis>
			<x>1</x>
			<y>0</y>
			<z>0</z>
		</axis>
		<action>
			<binding>
				<condition>
					<equals>
						<property>systems/engines/limit/active-mode-int</property>
						<value>5</value>
					</equals>
				</condition>
				<command>property-adjust</command>
				<property>systems/engines/limit/flex-temp</property>
				<factor>1</factor>
				<min>1</min>
				<max>59</max>
				<wrap>false</wrap>
			</binding>
			<binding>
				<command>property-adjust</command>
				<property>controls/cockpit/trp/assumed-temp-rotate</property>
				<factor>1</factor>
				<min>0</min>
				<max>100000</max>
				<wrap>true</wrap>
			</binding>
		</action>
	</animation>
	
	<animation>
		<type>pick</type>
		<object-name>toBtn</object-name>
		<action>
			<button>0</button>
			<repeatable>false</repeatable>
			<binding>
				<condition>
					<equals>
						<property>systems/dfgs/power-avail</property>
						<value>1</value>
					</equals>
				</condition>
				<command>nasal</command>
				<script>systems.THRLIM.setMode(0);</script>
			</binding>
			<binding>
				<command>property-assign</command>
				<property>controls/cockpit/trp/to</property>
				<value>1</value>
			</binding>
			<binding>
				<command>nasal</command>
				<script>core.Sound.btn1();</script>
			</binding>
			<mod-up>
				<binding>
					<command>property-assign</command>
					<property>controls/cockpit/trp/to</property>
					<value>0</value>
				</binding>
			</mod-up>
		</action>
	</animation>
	
