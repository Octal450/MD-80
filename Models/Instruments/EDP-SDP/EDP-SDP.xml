<PropertyList>

	<path>EDP-SDP.ac</path>
	
    <effect>
		<object-name>EDPSDP.Decals</object-name>
        <inherits-from>Effects/model-transparent</inherits-from>
    </effect>
	
	<!-- No lights without power! -->
	<animation>
		<type>select</type>
		<object-name>EDPLight.RevThrL</object-name>
		<object-name>EDPLight.RevThrR</object-name>
		<object-name>EDPLight.RevUnlckL</object-name>
		<object-name>EDPLight.RevUnlckR</object-name>
		<object-name>SDPLight.HydQtyL</object-name>
		<object-name>SDPLight.HydQtyR</object-name>
		<object-name>SDPLight.OilPressL1</object-name>
		<object-name>SDPLight.OilPressL2</object-name>
		<object-name>SDPLight.OilPressR1</object-name>
		<object-name>SDPLight.OilPressR2</object-name>
		<object-name>SDPLight.OilTempL1</object-name>
		<object-name>SDPLight.OilTempL2</object-name>
		<object-name>SDPLight.OilTempR1</object-name>
		<object-name>SDPLight.OilTempR2</object-name>
		<object-name>SDPLight.SlatsAuto</object-name>
		<object-name>SDPLight.SlatsDisag</object-name>
		<object-name>SDPLight.SlatsLand</object-name>
		<object-name>SDPLight.SlatsTO</object-name>
		<condition>
			<greater-than-equals>
				<property>systems/electrical/outputs/efis</property>
				<value>25</value>
			</greater-than-equals>
		</condition>
	</animation>
	
	<!-- Not yet implemented! -->
	<animation>
		<type>select</type>
		<object-name>SDPLight.HydQtyL</object-name>
		<object-name>SDPLight.HydQtyR</object-name>
		<object-name>SDPLight.OilPressL1</object-name>
		<object-name>SDPLight.OilPressL2</object-name>
		<object-name>SDPLight.OilPressR1</object-name>
		<object-name>SDPLight.OilPressR2</object-name>
		<object-name>SDPLight.OilTempL1</object-name>
		<object-name>SDPLight.OilTempL2</object-name>
		<object-name>SDPLight.OilTempR1</object-name>
		<object-name>SDPLight.OilTempR2</object-name>
		<condition>
			<property>controls/switches/annun-test</property>
		</condition>
	</animation>
	
	<!-- Reverser Lights -->
	<animation>
		<type>select</type>
		<object-name>EDPLight.RevThrL</object-name>
		<condition>
			<or>
				<greater-than-equals>
					<property>systems/engines/reverse-1/position-norm</property>
					<value>0.95</value>
				</greater-than-equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>

	<animation>
		<type>select</type>
		<object-name>EDPLight.RevThrR</object-name>
		<condition>
			<or>
				<greater-than-equals>
					<property>systems/engines/reverse-2/position-norm</property>
					<value>0.95</value>
				</greater-than-equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>
	
	<animation>
		<type>select</type>
		<object-name>EDPLight.RevUnlckL</object-name>
		<condition>
			<or>
				<greater-than-equals>
					<property>systems/engines/reverse-1/position-norm</property>
					<value>0.05</value>
				</greater-than-equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>

	<animation>
		<type>select</type>
		<object-name>EDPLight.RevUnlckR</object-name>
		<condition>
			<or>
				<greater-than-equals>
					<property>systems/engines/reverse-2/position-norm</property>
					<value>0.05</value>
				</greater-than-equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>
	
	<!-- Slat Lights -->
	<animation>
		<type>select</type>
		<object-name>SDPLight.SlatsTO</object-name>
		<condition>
			<or>
				<equals>
					<property>instrumentation/flap-slat/slat</property>
					<value>1</value>
				</equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>
	<animation>
		<type>select</type>
		<object-name>SDPLight.SlatsDisag</object-name>
		<condition>
			<or>
				<equals>
					<property>instrumentation/flap-slat/slat</property>
					<value>2</value>
				</equals>
				<equals>
					<property>instrumentation/flap-slat/slat</property>
					<value>3</value>
				</equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>
	<animation>
		<type>select</type>
		<object-name>SDPLight.SlatsAuto</object-name>
		<condition>
			<or>
				<equals>
					<property>instrumentation/flap-slat/slat</property>
					<value>3</value>
				</equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>
	<animation>
		<type>select</type>
		<object-name>SDPLight.SlatsLand</object-name>
		<condition>
			<or>
				<equals>
					<property>instrumentation/flap-slat/slat</property>
					<value>4</value>
				</equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>

</PropertyList>