<PropertyList>

	<path>EDP-SDP.ac</path>
	
    <effect>
		<object-name>EDPSDP.Decals</object-name>
        <inherits-from>Effects/model-transparent</inherits-from>
    </effect>
	
	<animation>
		<type>material</type>
		<object-name>EDPSDP.Decals</object-name>
		<emission>
			<red>1.0</red>
			<green>0.6</green>
			<blue>0.3</blue>
			<factor-prop>systems/lighting/center-panel</factor-prop>
		</emission>
	</animation>
	
	<!-- No lights without power! -->
	<animation>
		<type>select</type>
		<object-name>EDPLight.RevThrL</object-name>
		<object-name>EDPLight.RevThrR</object-name>
		<object-name>EDPLight.RevUnlckL</object-name>
		<object-name>EDPLight.RevUnlckR</object-name>
		<object-name>SDPLight.HydQtyL</object-name>
		<object-name>SDPLight.HydQtyR</object-name>
		<object-name>SDPLight.OilPressL1</object-name>
		<object-name>SDPLight.OilPressL2</object-name>
		<object-name>SDPLight.OilPressR1</object-name>
		<object-name>SDPLight.OilPressR2</object-name>
		<object-name>SDPLight.OilTempL1</object-name>
		<object-name>SDPLight.OilTempL2</object-name>
		<object-name>SDPLight.OilTempR1</object-name>
		<object-name>SDPLight.OilTempR2</object-name>
		<object-name>SDPLight.SlatsAuto</object-name>
		<object-name>SDPLight.SlatsDisag</object-name>
		<object-name>SDPLight.SlatsLand</object-name>
		<object-name>SDPLight.SlatsTO</object-name>
		<condition>
			<greater-than-equals>
				<property>systems/electrical/outputs/efis</property>
				<value>25</value>
			</greater-than-equals>
		</condition>
	</animation>
	
	<!-- Not yet implemented! -->
	<animation>
		<type>select</type>
		<object-name>SDPLight.HydQtyL</object-name>
		<object-name>SDPLight.HydQtyR</object-name>
		<object-name>SDPLight.OilPressL1</object-name>
		<object-name>SDPLight.OilPressL2</object-name>
		<object-name>SDPLight.OilPressR1</object-name>
		<object-name>SDPLight.OilPressR2</object-name>
		<object-name>SDPLight.OilTempL1</object-name>
		<object-name>SDPLight.OilTempL2</object-name>
		<object-name>SDPLight.OilTempR1</object-name>
		<object-name>SDPLight.OilTempR2</object-name>
		<condition>
			<property>controls/switches/annun-test</property>
		</condition>
	</animation>
	
	<!-- Reverser Lights -->
	<animation>
		<type>select</type>
		<object-name>EDPLight.RevThrL</object-name>
		<condition>
			<or>
				<greater-than-equals>
					<property>systems/engines/reverse-1/position-norm</property>
					<value>0.95</value>
				</greater-than-equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>

	<animation>
		<type>select</type>
		<object-name>EDPLight.RevThrR</object-name>
		<condition>
			<or>
				<greater-than-equals>
					<property>systems/engines/reverse-2/position-norm</property>
					<value>0.95</value>
				</greater-than-equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>
	
	<animation>
		<type>select</type>
		<object-name>EDPLight.RevUnlckL</object-name>
		<condition>
			<or>
				<greater-than-equals>
					<property>systems/engines/reverse-1/position-norm</property>
					<value>0.05</value>
				</greater-than-equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>

	<animation>
		<type>select</type>
		<object-name>EDPLight.RevUnlckR</object-name>
		<condition>
			<or>
				<greater-than-equals>
					<property>systems/engines/reverse-2/position-norm</property>
					<value>0.05</value>
				</greater-than-equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>
	
	<!-- Slat Lights -->
	<animation>
		<type>select</type>
		<object-name>SDPLight.SlatsTO</object-name>
		<condition>
			<or>
				<equals>
					<property>instrumentation/flap-slat/slat</property>
					<value>1</value>
				</equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>
	<animation>
		<type>select</type>
		<object-name>SDPLight.SlatsDisag</object-name>
		<condition>
			<or>
				<equals>
					<property>instrumentation/flap-slat/slat</property>
					<value>2</value>
				</equals>
				<equals>
					<property>instrumentation/flap-slat/slat</property>
					<value>3</value>
				</equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>
	<animation>
		<type>select</type>
		<object-name>SDPLight.SlatsAuto</object-name>
		<condition>
			<or>
				<equals>
					<property>instrumentation/flap-slat/slat</property>
					<value>3</value>
				</equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>
	<animation>
		<type>select</type>
		<object-name>SDPLight.SlatsLand</object-name>
		<condition>
			<or>
				<equals>
					<property>instrumentation/flap-slat/slat</property>
					<value>4</value>
				</equals>
				<equals>
					<property>controls/switches/annun-test</property>
					<value>1</value>
				</equals>
			</or>
		</condition>
	</animation>
	
	<!-- Fuel Used Reset -->
	<animation>
		<type>pick</type>
		<object-name>EDPButton.FuelReset</object-name>
		<action>
			<button>0</button>
			<repeatable>false</repeatable>
			<binding>
				<command>property-assign</command>
				<property>controls/engines/fu-reset</property>
				<value>1</value>
			</binding>
			<binding>
				<command>nasal</command>
				<script>core.Sound.btn1();</script>
			</binding>
			<mod-up>
				<binding>
					<command>property-assign</command>
					<property>controls/engines/fu-reset</property>
					<value>0</value>
				</binding>
			</mod-up>
		</action>
	</animation>
	<animation>
		<type>translate</type>
		<object-name>EDPButton.FuelReset</object-name>
		<property>controls/engines/fu-reset</property>
		<factor>-0.002</factor>
		<axis>
			<x>1</x>
			<y>0</y>
			<z>0</z>
		</axis>
	</animation>
	
	<!-- MAN EPR Knobs -->
	<animation>
		<type>rotate</type>
		<object-name>EDPKnob.EPRL</object-name>
		<property>controls/cockpit/epr-cmd-rotate[0]</property>
		<factor>-11.25</factor>
		<center>
			<x-m>0</x-m>
			<y-m>-0.09647</y-m>
			<z-m>-0.10583</z-m>
		</center>
		<axis>
			<x>1</x>
			<y>0</y>
			<z>0</z>
		</axis>
	</animation>
	<animation>
		<type>translate</type>
		<object-name>EDPKnob.EPRL</object-name>
		<property>controls/engines/engine[0]/man-epr-set</property>
		<factor>0.007</factor>
		<axis>
			<x>1</x>
			<y>0</y>
			<z>0</z>
		</axis>
	</animation>
	<animation>
		<type>pick</type>
		<object-name>EDPKnob.EPRL</object-name>
		<action>
			<button>0</button>
			<button>1</button>
			<repeatable>false</repeatable>
			<binding>
				<command>property-toggle</command>
				<property>controls/engines/engine[0]/man-epr-set</property>
			</binding>
		</action>
		<action>
			<button>3</button>
			<repeatable>true</repeatable>
			<binding>
				<condition>
					<not><property>devices/status/keyboard/shift</property></not>
				</condition>
				<command>nasal</command>
				<script>systems.ENGINES.adjustManEpr(0, 1);</script>
			</binding>
			<binding>
				<condition>
					<property>devices/status/keyboard/shift</property>
				</condition>
				<command>nasal</command>
				<script>systems.ENGINES.adjustManEpr(0, 10);</script>
			</binding>
			<binding>
				<command>property-adjust</command>
				<property>controls/cockpit/epr-cmd-rotate[0]</property>
				<step>1</step>
				<min>0</min>
				<max>100000</max>
				<wrap>true</wrap>
			</binding>
		</action>
		<action>
			<button>4</button>
			<repeatable>true</repeatable>
			<binding>
				<condition>
					<not><property>devices/status/keyboard/shift</property></not>
				</condition>
				<command>nasal</command>
				<script>systems.ENGINES.adjustManEpr(0, -1);</script>
			</binding>
			<binding>
				<condition>
					<property>devices/status/keyboard/shift</property>
				</condition>
				<command>nasal</command>
				<script>systems.ENGINES.adjustManEpr(0, -10);</script>
			</binding>
			<binding>
				<command>property-adjust</command>
				<property>controls/cockpit/epr-cmd-rotate[0]</property>
				<step>-1</step>
				<min>0</min>
				<max>100000</max>
				<wrap>true</wrap>
			</binding>
		</action>
	</animation>
	
	<animation>
		<type>rotate</type>
		<object-name>EDPKnob.EPRR</object-name>
		<property>controls/cockpit/epr-cmd-rotate[1]</property>
		<factor>-11.25</factor>
		<center>
			<x-m>0</x-m>
			<y-m>0.01005</y-m>
			<z-m>-0.10583</z-m>
		</center>
		<axis>
			<x>1</x>
			<y>0</y>
			<z>0</z>
		</axis>
	</animation>
	<animation>
		<type>translate</type>
		<object-name>EDPKnob.EPRR</object-name>
		<property>controls/engines/engine[1]/man-epr-set</property>
		<factor>0.007</factor>
		<axis>
			<x>1</x>
			<y>0</y>
			<z>0</z>
		</axis>
	</animation>
	<animation>
		<type>pick</type>
		<object-name>EDPKnob.EPRR</object-name>
		<action>
			<button>0</button>
			<button>1</button>
			<repeatable>false</repeatable>
			<binding>
				<command>property-toggle</command>
				<property>controls/engines/engine[1]/man-epr-set</property>
			</binding>
		</action>
		<action>
			<button>3</button>
			<repeatable>true</repeatable>
			<binding>
				<condition>
					<not><property>devices/status/keyboard/shift</property></not>
				</condition>
				<command>nasal</command>
				<script>systems.ENGINES.adjustManEpr(1, 1);</script>
			</binding>
			<binding>
				<condition>
					<property>devices/status/keyboard/shift</property>
				</condition>
				<command>nasal</command>
				<script>systems.ENGINES.adjustManEpr(1, 10);</script>
			</binding>
			<binding>
				<command>property-adjust</command>
				<property>controls/cockpit/epr-cmd-rotate[1]</property>
				<step>1</step>
				<min>0</min>
				<max>100000</max>
				<wrap>true</wrap>
			</binding>
		</action>
		<action>
			<button>4</button>
			<repeatable>true</repeatable>
			<binding>
				<condition>
					<not><property>devices/status/keyboard/shift</property></not>
				</condition>
				<command>nasal</command>
				<script>systems.ENGINES.adjustManEpr(1, -1);</script>
			</binding>
			<binding>
				<condition>
					<property>devices/status/keyboard/shift</property>
				</condition>
				<command>nasal</command>
				<script>systems.ENGINES.adjustManEpr(1, -10);</script>
			</binding>
			<binding>
				<command>property-adjust</command>
				<property>controls/cockpit/epr-cmd-rotate[1]</property>
				<step>-1</step>
				<min>0</min>
				<max>100000</max>
				<wrap>true</wrap>
			</binding>
		</action>
	</animation>

</PropertyList>